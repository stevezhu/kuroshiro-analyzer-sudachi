{
  "name": "kuroshiro-analyzer-sudachi",
  "version": "0.1.0",
  "description": "Sudachi morphological analyzer for kuroshiro, backed by sudachi-wasm333 + SudachiDict",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "kuroshiro",
    "sudachi",
    "japanese",
    "morphological",
    "analyzer",
    "tokenizer",
    "wasm",
    "kanji",
    "kana",
    "hiragana",
    "katakana",
    "romaji",
    "furigana"
  ],
  "author": "Steve Zhu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevezhu/kuroshiro-analyzer-sudachi.git"
  },
  "bugs": {
    "url": "https://github.com/stevezhu/kuroshiro-analyzer-sudachi/issues"
  },
  "homepage": "https://github.com/stevezhu/kuroshiro-analyzer-sudachi#readme",
  "dependencies": {
    "sudachi-wasm333": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.28.1"
}
